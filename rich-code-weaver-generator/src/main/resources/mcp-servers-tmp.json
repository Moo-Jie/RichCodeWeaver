{
  "mcpServers": {
    "baidu-map": {
      "command": "${mcp.baidu-map.command:npm}",
      "args": [
        "exec",
        "--yes",
        "@baidumap/mcp-server-baidu-map"
      ],
      "env": {
        "BAIDU_MAP_API_KEY": "${BAIDU_MAP_API_KEY:${baidu.qianfan.appbuilder-api-key}}"
      }
    }
  }
}
